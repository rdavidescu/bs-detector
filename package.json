{
  "name": "bs-detector",
  "version": "0.1.0",
  "description": "Chrome extension that uses AI to detect BS in web pages through content analysis",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage-check": "vitest run --coverage && node scripts/check-coverage.js",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "devDependencies": {
    "vitest": "^3.1.1",
    "eslint": "^9.25.0",
    "@vitest/coverage-v8": "^3.1.1",
    "happy-dom": "^17.4.4",
    "msw": "^2.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
